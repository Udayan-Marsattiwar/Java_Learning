-> More Efficient Implementation of the Above Approach
a. Using two pointers lo = 0 and hi = last index.
b. Run a while loop; if arr[lo] is odd and arr[hi] is even then we will swap them else we will decrement hi.



import java.util.Arrays;
​
public class Main {
    // Function to segregate even and odd numbers
    static void segregate(int[] arr) {
        int lo = 0, hi = arr.length - 1;
​
        while (hi >= lo) {
            if (arr[lo] % 2 != 0) {
                if (arr[hi] % 2 == 0) {
                  
                    // Swap arr[lo] and arr[hi]
                    int temp = arr[lo];
                    arr[lo] = arr[hi];
                    arr[hi] = temp;
                  
                    lo++;
                    hi--;
                } else {
                    hi--;
                }
            } else {
                lo++;
            }
        }
    }
