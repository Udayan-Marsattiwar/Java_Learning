    static void reverseArray(int arr[])
    {
        int n = arr.length;
        //declare a stack
        Stack<Integer> st = new Stack<>();
        
        //push array elements into stack
        for (int i = 0; i < n; i++) {
            st.push(arr[i]);
        }
        
        // update elements of array 
