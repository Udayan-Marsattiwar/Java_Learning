// Here we have intialized BigInteger by 3 methods.

import java.math.BigInteger;
class Main {
    public static void main(String[] args) {
        BigInteger a = new BigInteger("12345678910123654789");
        String b = "1234567891023654";
        System.out.println(a);
        a = new BigInteger(b);
        BigInteger c = BigInteger.valueOf(67899638);
        System.out.println(a);
        System.out.println(b);
        System.out.println(c);
    }
}

